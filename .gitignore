# =============================================================================
# Dotfiles .gitignore
# =============================================================================

# ─── macOS ──────────────────────────────────────────────────────────────────
.DS_Store
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
.DocumentRevisions-V100
.fseventsd
.com.apple.timemachine.donotpresent

# ─── Editors ────────────────────────────────────────────────────────────────
*.swp
*.swo
*~
.idea/
.vscode/

# ─── Node / Build ──────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.map
*.o
*.obj
*.class

# ─── Secrets & Credentials ─────────────────────────────────────────────────
.env
.env.*
!.env.example
*.secret
*.key
*.pem
*.cert
*.token
*_rsa
*_dsa
*_ecdsa
*_ed25519
api_key
credentials.json
.secrets/
zsh/config/secrets.zsh
.git-credentials
.gitconfig.local
.netrc
.npmrc

# ─── SSH ────────────────────────────────────────────────────────────────────
ssh/

# ─── Local Overrides ───────────────────────────────────────────────────────
*.local
*.private
local.sh
private.sh
.zshrc.local
.zshenv.local
.bashrc.local

# ─── Shell State ────────────────────────────────────────────────────────────
zsh/.zsh_history
zsh/.zsh_sessions/
zsh/.zcompcache/
zsh/.zcompdump*

# ─── Cache ──────────────────────────────────────────────────────────────────
.cache/
*.cache

# ─── Backups & Temp ────────────────────────────────────────────────────────
*.backup
*.bak
*.tmp
*.temp
.tmp/
.temp/
.dotfiles-backup-*/
sketchybar.backup/

# ─── Application Data (not config) ─────────────────────────────────────────
Battle.net/
avante.nvim/
qBittorrent/
configstore/
uv/

# ─── Abandoned / Unused Configs ────────────────────────────────────────────
lvim/
fish/
neofetch/
mpv/

# ─── Tool-Specific ─────────────────────────────────────────────────────────
# Raycast extensions and build artifacts
raycast/

# Old archived configs
archive/

# Tmux plugins (installed by TPM at runtime)
tmux/plugins/

# ─── Private / Auth Configs ────────────────────────────────────────────────
github-copilot/
gh/hosts.yml
acli/
.claude/
claude-hooks/projects.json

# ─── T3 Code ──────────────────────────────────────────────────────────────
favicon.svg

# ─── Untracked Projects ────────────────────────────────────────────────────
ccstatusline/
mole/
